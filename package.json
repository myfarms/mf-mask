{
  "name": "@myfarms/mf-mask",
  "version": "2.0.0",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "docs": "npm run docs:build",
    "docs:build": "compodoc -p tsconfig.json -n @myfarms/mf-mask -d docs --hideGenerator",
    "docs:serve": "npm run docs:build -- -s",
    "docs:watch": "npm run docs:build -- -s -w",
    "lite": "lite-server",
    "playground:build": "tsc -p playground -w",
    "preplayground": "mkdir -p .playground && node_modules/.bin/esbuild node_modules/rxjs/dist/esm5/index.js --bundle --format=esm --outfile=.playground/rxjs.mjs",
    "playground": "concurrently --kill-others \"npm run build:watch\" \"npm run playground:build\" \"npm run lite\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterFramework": [
      "<rootDir>/src/jest.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "<rootDir>/src/tsconfig.spec.json"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myfarms/mf-mask"
  },
  "author": {
    "name": "MyFarms",
    "email": "administrator@myfarms.com"
  },
  "contributors": [
    {
      "name": "Adam Keenan",
      "email": "adam.g.keenan@gmail.com"
    }
  ],
  "keywords": [
    "angular"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/myfarms/mf-mask/issues"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~13.3.0",
    "@angular/common": "^13.0.0",
    "@angular/compiler": "^13.0.0",
    "@angular/compiler-cli": "^13.0.0",
    "@angular/core": "^13.0.0",
    "@angular/forms": "^13.0.0",
    "@angular/platform-browser": "^13.0.0",
    "@angular/platform-browser-dynamic": "^13.0.0",
    "@compodoc/compodoc": "^1.1.19",
    "@types/babel__traverse": "~7.14.0",
    "@types/jest": "^27.4.0",
    "@types/node": "~14.18.0",
    "concurrently": "^7.0.0",
    "core-js": "^2.6.11",
    "jest": "^27.4.7",
    "jest-preset-angular": "^11.1.0",
    "lite-server": "^2.6.1",
    "ng-packagr": "^13.0.0",
    "rxjs": "~7.5.0",
    "systemjs": "^0.20.12",
    "ts-node": "~10.4.0",
    "typescript": "~4.6.0",
    "zone.js": "~0.11.4"
  },
  "engines": {
    "node": ">=14.15.0"
  },
  "overrides": {
    "@angular-devkit/build-angular": "~13.3.0",
    "@types/babel__traverse": "~7.14.0",
    "@types/node": "~14.18.0"
  },
  "dependencies": {}
}
