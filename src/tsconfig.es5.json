{
  "compilerOptions": {
    "declaration": true,
    "module": "commonjs",
    "target": "es2020",
    "baseUrl": ".",
    "stripInternal": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "types": []
  }
}
