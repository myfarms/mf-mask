{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "types": []
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  }
}
